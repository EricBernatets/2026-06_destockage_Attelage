<script>
function filterArticles() {
  var q = document.getElementById('search-input').value.toLowerCase().trim();
  var rows = document.querySelectorAll('#articles-body .article-row');
  var visible = 0;
  rows.forEach(function(row) {
    var text = row.textContent.toLowerCase();
    if (!q || text.includes(q)) {
      row.classList.remove('hidden');
      visible++;
    } else {
      row.classList.add('hidden');
    }
  });
  document.getElementById('results-count').textContent =
    visible + ' article' + (visible > 1 ? 's' : '');
}

function sendOrder() {
  var societe = document.getElementById('societe').value.trim();
  var contact = document.getElementById('contact').value.trim();
  var email   = document.getElementById('email').value.trim();

  if (!societe || !contact || !email) {
    alert('Merci de renseigner la societe, le contact et l email.');
    return;
  }

  var lines = [];
  document.querySelectorAll('.qty-input').forEach(function(inp) {
    var qty = parseInt(inp.value) || 0;
    if (qty > 0) {
      var price = parseFloat(inp.dataset.price) || 0;
      var montant = (qty * price).toFixed(2).replace('.', ',');
      lines.push(inp.dataset.code + ' | ' + inp.dataset.name + ' | x' + qty + ' | ' + montant + ' EUR HT');
    }
  });

  if (lines.length === 0) {
    alert('Veuillez indiquer une quantite pour au moins un article.');
    return;
  }

  var tel = document.getElementById('tel').value.trim();
  var remarques = document.getElementById('remarques').value.trim();
  var totalTxt = document.getElementById('total-display').innerText;

  var corps = 'Societe : ' + societe + '%0D%0A';
  corps += 'Contact : ' + contact + '%0D%0A';
  corps += 'Email   : ' + email + '%0D%0A';
  if (tel) { corps += 'Tel     : ' + tel + '%0D%0A'; }
  corps += '%0D%0AARTICLES COMMANDES :%0D%0A';
  for (var i = 0; i < lines.length; i++) {
    corps += lines[i] + '%0D%0A';
  }
  corps += '%0D%0ATOTAL HT : ' + totalTxt;
  if (remarques) { corps += '%0D%0A%0D%0ARemarques : ' + remarques; }

  var sujet = encodeURIComponent('Commande Zilco - ' + societe);

  window.location.href = 'mailto:france@zilcoeurope.com?subject=' + sujet + '&body=' + corps;

  setTimeout(function() {
    document.getElementById('success-msg').style.display = 'block';
  }, 800);
}

function updateTotal() {
  var total = 0;
  document.querySelectorAll('.qty-input').forEach(function(inp) {
    var qty = parseInt(inp.value) || 0;
    var price = parseFloat(inp.dataset.price) || 0;
    total += qty * price;
  });
  document.getElementById('total-display').innerHTML =
    total.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' <span>&euro;</span>';
}
</script>
</body>
</html>
