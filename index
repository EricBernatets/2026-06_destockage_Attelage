<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    background: #111;
    color: #f0f0f0;
    min-height: 100vh;
  }

  /* HEADER */
  .header {
    background: #000;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 3px solid #CC0000;
  }
  .header img { height: 42px; }
  .header-contact { font-size: 12px; color: #888; text-align: right; line-height: 1.7; }
  .header-contact a { color: #CC0000; text-decoration: none; }

  /* HERO BANNER */
  .hero-banner {
    width: 100%;
    display: block;
    max-height: 420px;
    object-fit: cover;
    object-position: center top;
  }

  /* SUBTITLE BAR */
  .subtitle-bar {
    background: #1a1a1a;
    border-bottom: 1px solid #2a2a2a;
    padding: 12px 24px;
    text-align: center;
  }
  .subtitle-bar p {
    font-size: 12px;
    color: #888;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* REMISE LEGEND */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    padding: 16px 24px 8px;
    max-width: 860px;
    margin: 0 auto;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #aaa;
  }
  .legend-dot {
    width: 12px; height: 12px; border-radius: 50%;
    display: inline-block;
  }

  /* CONTAINER */
  .container { max-width: 860px; margin: 0 auto; padding: 8px 16px 48px; }

  /* SEARCH */
  .search-wrap {
    margin: 16px 0 4px;
    position: relative;
  }
  .search-input {
    width: 100%;
    background: #1a1a1a;
    border: 1px solid #333;
    color: #f0f0f0;
    padding: 10px 14px 10px 36px;
    font-size: 14px;
    font-family: inherit;
    outline: none;
    border-radius: 0;
    -webkit-appearance: none;
    transition: border-color 0.2s;
  }
  .search-input:focus { border-color: #CC0000; }
  .search-icon {
    position: absolute;
    left: 10px; top: 50%;
    transform: translateY(-50%);
    color: #555;
    font-size: 14px;
    pointer-events: none;
  }
  .results-count {
    font-size: 11px;
    color: #555;
    margin: 6px 0 10px;
    letter-spacing: 0.5px;
  }

  /* SECTION TITLE */
  .section-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #CC0000;
    margin: 22px 0 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid #2a2a2a;
  }

  /* CLIENT FIELDS */
  .field-group { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 10px; }
  .field-group.full { grid-template-columns: 1fr; }
  label { display: block; font-size: 10px; color: #777; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 5px; }
  input[type="text"], input[type="email"], input[type="tel"], textarea {
    width: 100%; background: #1a1a1a; border: 1px solid #2e2e2e;
    color: #f0f0f0; padding: 10px 12px; font-size: 14px; font-family: inherit;
    outline: none; transition: border-color 0.2s; border-radius: 0; -webkit-appearance: none;
  }
  input[type="text"]:focus, input[type="email"]:focus, input[type="tel"]:focus, textarea:focus { border-color: #CC0000; }
  textarea { resize: vertical; min-height: 70px; }

  /* TABLE */
  .articles-table { width: 100%; border-collapse: collapse; margin-top: 4px; }
  .articles-table thead th {
    background: #1a1a1a; font-size: 10px; letter-spacing: 1.5px;
    text-transform: uppercase; color: #666; padding: 10px 10px;
    text-align: left; font-weight: 600; position: sticky; top: 0; z-index: 2;
  }
  .articles-table thead th.right { text-align: right; }
  .articles-table thead th.center { text-align: center; }

  .article-row { border-bottom: 1px solid #1e1e1e; transition: background 0.12s; }
  .article-row:hover { background: #1c1c1c; }
  .article-row.hidden { display: none; }
  .article-row td { padding: 9px 10px; vertical-align: middle; }

  .article-code { font-size: 11px; color: #555; font-family: monospace; }
  .article-name { font-size: 13px; color: #ddd; line-height: 1.3; }
  .price-cat { font-size: 11px; color: #444; text-decoration: line-through; text-align: right; white-space: nowrap; }
  .price-promo { font-size: 15px; font-weight: 900; color: #e8e8e8; text-align: right; white-space: nowrap; }

  .badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 800;
    padding: 3px 7px;
    border-radius: 3px;
    color: #fff;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }

  .qty-input {
    width: 58px; background: #1a1a1a; border: 1px solid #3a3a3a;
    color: #fff; padding: 8px 4px; font-size: 15px; font-weight: 700;
    text-align: center; font-family: inherit; outline: none;
    transition: border-color 0.2s; -webkit-appearance: none; border-radius: 0;
  }
  .qty-input:focus { border-color: #CC0000; }

  /* TOTAL */
  .total-bar {
    background: #1a1a1a; border: 1px solid #2a2a2a;
    padding: 16px 20px; margin-top: 20px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .total-label { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: #777; }
  .total-amount { font-size: 28px; font-weight: 900; color: #fff; }
  .total-amount span { color: #CC0000; font-size: 16px; }

  /* SUBMIT */
  .submit-btn {
    width: 100%; margin-top: 20px; background: #CC0000; color: #fff;
    border: none; padding: 18px; font-size: 14px; font-weight: 900;
    text-transform: uppercase; letter-spacing: 3px; cursor: pointer;
    font-family: inherit; transition: background 0.2s;
    display: block; text-align: center; text-decoration: none;
  }
  .submit-btn:hover { background: #aa0000; }
  .submit-btn:disabled { background: #444; cursor: not-allowed; }

  .success-msg {
    display: none; background: #0a220a; border: 1px solid #2a6a2a;
    color: #88ee88; padding: 20px; text-align: center;
    margin-top: 16px; font-size: 14px; line-height: 1.7;
  }

  /* FOOTER */
  .footer {
    background: #000; border-top: 1px solid #1e1e1e;
    padding: 20px 24px; text-align: center;
    font-size: 11px; color: #444; line-height: 1.9;
  }
  .footer a { color: #666; text-decoration: none; }

  @media (max-width: 600px) {
    .field-group { grid-template-columns: 1fr; }
    .articles-table thead th.hide-mobile,
    .articles-table td.hide-mobile { display: none; }
    .article-name { font-size: 12px; }
  }
</style>
